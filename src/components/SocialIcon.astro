---
interface Props {
  label: string;
}

const { label } = Astro.props;
const kind = label.toLowerCase();
---

{
  kind === "instagram" ? (
    <svg class="social-icon social-icon-instagram" aria-hidden="true" viewBox="0 0 24 24">
      <rect class="icon-line" x="5" y="5" width="14" height="14" rx="4" />
      <circle class="icon-line" cx="12" cy="12" r="3.15" />
      <circle class="icon-fill" cx="16.2" cy="7.8" r="0.85" />
    </svg>
  ) : kind === "facebook" ? (
    <svg class="social-icon social-icon-facebook" aria-hidden="true" viewBox="0 0 24 24">
      <path class="icon-fill" d="M14.1 8.6V11h3.1l-.5 3.2h-2.6V21h-3.5v-6.8H8V11h2.6V8.4c0-2.7 1.6-4.3 4.1-4.3.9 0 1.9.1 2.4.2v3h-1.5c-1.1 0-1.5.5-1.5 1.3Z" />
    </svg>
  ) : (
    <svg class="social-icon social-icon-tripadvisor" aria-hidden="true" viewBox="0 0 32 24">
      <path
        class="icon-line"
        d="M2.9 8.5h5.2A8.8 8.8 0 0 1 16 5.2a8.8 8.8 0 0 1 7.9 3.3h5.2l-3.5 3.7c.2.7.4 1.5.4 2.3a5.35 5.35 0 0 1-9.8 3l-.2-.3-.2.3a5.35 5.35 0 0 1-9.8-3c0-.8.1-1.6.4-2.3L2.9 8.5Z"
      />
      <circle class="icon-line" cx="10" cy="14.4" r="2.7" />
      <circle class="icon-line" cx="22" cy="14.4" r="2.7" />
      <circle class="icon-fill" cx="10" cy="14.4" r="0.8" />
      <circle class="icon-fill" cx="22" cy="14.4" r="0.8" />
      <path class="icon-line" d="M13.1 14.4h5.8" />
    </svg>
  )
}
