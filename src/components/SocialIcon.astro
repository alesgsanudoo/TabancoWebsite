---
interface Props {
  label: string;
}

const { label } = Astro.props;
const kind = label.toLowerCase();
---

{
  kind === "instagram" ? (
    <svg aria-hidden="true" viewBox="0 0 24 24">
      <rect x="5" y="5" width="14" height="14" rx="4" />
      <circle cx="12" cy="12" r="3.15" />
      <circle cx="16.2" cy="7.8" r="0.85" />
    </svg>
  ) : kind === "facebook" ? (
    <svg aria-hidden="true" viewBox="0 0 24 24">
      <path d="M14.1 8.6V11h3.1l-.5 3.2h-2.6V21h-3.5v-6.8H8V11h2.6V8.4c0-2.7 1.6-4.3 4.1-4.3.9 0 1.9.1 2.4.2v3h-1.5c-1.1 0-1.5.5-1.5 1.3Z" />
    </svg>
  ) : (
    <svg aria-hidden="true" viewBox="0 0 24 24">
      <path d="M3.5 9.4h3.2c1-.8 2.2-1.2 3.6-1.2h3.4c1.4 0 2.6.4 3.6 1.2h3.2l-2 2.2c.2.6.3 1.1.3 1.8a4.2 4.2 0 0 1-7.8 2.2l-3 3.3-3-3.3a4.2 4.2 0 0 1-7.8-2.2c0-.7.1-1.2.3-1.8L3.5 9.4Z" />
      <circle cx="6.5" cy="13.4" r="1.65" />
      <circle cx="17.5" cy="13.4" r="1.65" />
    </svg>
  )
}
